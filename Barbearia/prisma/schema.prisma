generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agendamento {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String
  servico   String
  data      DateTime
  criadoEm  DateTime @default(now())
}